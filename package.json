{
  "name": "financial-web-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:watch": "while true; do npm run dev; echo 'Server exited. Restarting in 2s...'; sleep 2; done",
    "build": "NODE_OPTIONS='--max-old-space-size=1024' npx next build",
    "build:pack": "bash scripts/build-and-pack-next.sh",
    "start": "npx next start -p ${PORT:-3000}",
    "lint": "next lint",
    "export": "next build",
    "migrate": "tsx scripts/migrate.ts",
    "seed-admin": "tsx scripts/seed-admin.ts",
    "change-admin-password": "tsx scripts/change-admin-password.ts",
    "seed": "tsx scripts/seed.ts",
    "delete-loan-chats": "tsx scripts/delete-loan-chats.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:setup": "node scripts/setup.js",
    "test:api": "BASE_URL=http://localhost:3004 ./scripts/test-apis.sh",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop financial-web-app",
    "pm2:restart": "pm2 restart financial-web-app",
    "pm2:logs": "pm2 logs financial-web-app",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^12.0.0",
    "lucide-react": "^0.460.0",
    "mysql2": "^3.17.2",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.21.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "typescript": "^5.6.3"
  }
}
